# ── AI API KEYS ───────────────────────────────────────────────────────────
# API key for OpenRouter Chat models (e.g. gpt-4o-mini)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# API key for OpenAI embedding models (e.g. text-embedding-3-small)
OPENAI_API_KEY=your-openai-api-key-here

# ── DATABASE & VECTOR STORE ────────────────────────────────────────────────
# Qdrant host (defaults to 'localhost' for local dev, or 'qdrant' in Docker Compose)
QDRANT_HOST=localhost

# ── BACKEND SECURITY ──────────────────────────────────────────────────────
# Cryptographically secure 256-bit hex JWT signing secret.
# You can generate a random hex string in your terminal using:
# openssl rand -hex 32
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970

# ── PROFILE ENVIRONMENT ────────────────────────────────────────────────────
# Active profile. Use 'local' to run with Ollama local inference (phi3:mini / nomic-embed).
# Leave blank or use 'default' to run with cloud-based OpenAI / OpenRouter models.
SPRING_PROFILES_ACTIVE=local
